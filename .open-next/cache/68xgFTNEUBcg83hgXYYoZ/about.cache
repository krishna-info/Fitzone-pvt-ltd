",\"@id\":\"https://fitzone.in\",\"url\":\"https://fitzone.in\",\"telephone\":\"+91 77422 31208\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"P NO. 35B, SECTOR A, JODHPUR K.U.M. BHAGAT KI KOTHI, Rameshwar Nagar\",\"addressLocality\":\"Jodhpur\",\"addressRegion\":\"Rajasthan\",\"postalCode\":\"342005\",\"addressCountry\":\"IN\"},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":26.2389,\"longitude\":73.0243},\"openingHoursSpecification\":{\"@type\":\"OpeningHoursSpecification\",\"dayOfWeek\":[\"Monday\",\"Tuesday\",\"Wednesday\",\"Thursday\",\"Friday\",\"Saturday\"],\"opens\":\"09:00\",\"closes\":\"18:00\"},\"sameAs\":[\"https://facebook.com/fitzoneindia\",\"https://instagram.com/fitzoneindia\"]}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"WebSite\",\"name\":\"FitZone Apparels\",\"url\":\"https://fitzoneapparel.in\",\"potentialAction\":{\"@type\":\"SearchAction\",\"target\":\"https://fitzoneapparel.in/search?q={search_term_string}\",\"query-input\":\"required name=search_term_string\"}}</script><nav class=\"sticky top-0 z-50 w-full bg-white/80 backdrop-blur-md border-b border-gray-100\"><div class=\"max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"flex justify-between items-center h-20\"><a class=\"flex items-center gap-3\" href=\"/\"><img alt=\"FitZone Apparels\" fetchPriority=\"high\" width=\"56\" height=\"56\" decoding=\"async\" data-nimg=\"1\" class=\"rounded-md\" style=\"color:transparent;mix-blend-mode:multiply\" srcSet=\"/_next/image?url=%2Flogo.png&amp;w=64&amp;q=75 1x, /_next/image?url=%2Flogo.png&amp;w=128&amp;q=75 2x\" src=\"/_next/image?url=%2Flogo.png&amp;w=128&amp;q=75\"/><span class=\"text-xl font-extrabold text-brand-primary tracking-tight hidden sm:block\">FIT<span class=\"text-brand-secondary\">ZONE</span></span></a><div class=\"hidden md:flex items-center space-x-8\"><a class=\"text-sm font-medium transition-colors hover:text-brand-primary text-brand-muted\" href=\"/\">Home</a><a class=\"text-sm font-medium transition-colors hover:text-brand-primary text-brand-primary\" href=\"/about\">About</a><a class=\"text-sm font-medium transition-colors hover:text-brand-primary text-brand-muted\" href=\"/manufacturing\">Manufacturing</a><a class=\"text-sm font-medium transition-colors hover:text-brand-primary text-brand-muted\" href=\"/certifications\">Certifications</a><a class=\"text-sm font-medium transition-colors hover:text-brand-primary text-brand-muted\" href=\"/gallery\">Gallery</a><a class=\"text-sm font-medium transition-colors hover:text-brand-primary text-brand-muted\" href=\"/products\">Products</a><a class=\"text-sm font-medium transition-colors hover:text-brand-primary text-brand-muted\" href=\"/article\">Articles</a><a class=\"text-sm font-medium transition-colors hover:text-brand-primary text-brand-muted\" href=\"/contact\">Contact</a><button class=\"inline-flex items-center justify-center rounded-brand text-sm font-semibold transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary disabled:pointer-events-none disabled:opacity-50 bg-[#25D366] text-white hover:bg-[#128C7E] h-10 px-4 py-2 hidden lg:flex\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-message-circle w-4 h-4 mr-2\" aria-hidden=\"true\"><path d=\"M2.992 16.342a2 2 0 0 1 .094 1.167l-1.065 3.29a1 1 0 0 0 1.236 1.168l3.413-.998a2 2 0 0 1 1.099.092 10 10 0 1 0-4.777-4.719\"></path></svg>WhatsApp Us</button></div><div class=\"md:hidden flex items-center\"><button class=\"text-brand-dark p-2 focus:outline-none\" aria-label=\"Toggle menu\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu w-6 h-6\" aria-hidden=\"true\"><path d=\"M4 5h16\"></path><path d=\"M4 12h16\"></path><path d=\"M4 19h16\"></path></svg></button></div></div></div></nav><main id=\"main-content\" class=\"flex-grow\"><section class=\"relative h-[40vh] min-h-[300px] flex items-center justify-center bg-brand-dark overflow-hidden\"><div class=\"absolute inset-0 z-0\"><div class=\"absolute inset-0 bg-brand-dark/60 z-10\"></div><img alt=\"About FitZone\" fetchPriority=\"high\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover grayscale opacity-50\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1524275539700-cf51138f679b%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1524275539700-cf51138f679b%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1524275539700-cf51138f679b%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1524275539700-cf51138f679b%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1524275539700-cf51138f679b%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1524275539700-cf51138f679b%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1524275539700-cf51138f679b%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1524275539700-cf51138f679b%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1524275539700-cf51138f679b%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=3840&amp;q=75\"/></div><div class=\"relative z-20 text-center space-y-4 px-4\"><div style=\"opacity:0;transform:translateY(20px)\"><span class=\"text-brand-secondary font-bold uppercase tracking-widest text-sm\">Our Story</span><h1 class=\"text-4xl md:text-6xl font-extrabold text-white\">About FitZone</h1></div></div></section><section class=\"py-24 bg-white\"><div class=\"max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"flex flex-col lg:flex-row gap-16 items-center\"><div class=\"flex-1 space-y-6\" style=\"opacity:0;transform:translateX(-30px)\"><h2 class=\"text-3xl md:text-4xl font-bold text-brand-dark\">Built on Quality, <br/><span class=\"text-brand-primary\">Driven by Performance.</span></h2><div class=\"prose prose-lg text-brand-muted\"><p>Founded in Rajasthan, FitZone Apparels Pvt. Ltd. was born out of a passion for excellence in athletic wear. What started as a small manufacturing unit has evolved into a state-of-the-art facility serving clients across the country.</p><p>Our philosophy is simple: athlete-first design. Every stitch, every fabric choice, and every manufacturing step is optimized to provide maximum comfort and durability for the high-performance lifestyle.</p></div></div><div class=\"flex-1 relative aspect-video rounded-brand-lg overflow-hidden shadow-card\" style=\"opacity:0;transform:scale(0.95)\"><img alt=\"Our Manufacturing Legacy\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1593440428582-7429399486c1%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1593440428582-7429399486c1%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1593440428582-7429399486c1%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1593440428582-7429399486c1%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1593440428582-7429399486c1%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1593440428582-7429399486c1%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1593440428582-7429399486c1%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1593440428582-7429399486c1%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1593440428582-7429399486c1%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=3840&amp;q=75\"/></div></div></div></section><section class=\"py-24 bg-brand-surface\"><div class=\"max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"grid grid-cols-1 md:grid-cols-2 gap-8\"><div class=\"p-10 bg-white rounded-brand-lg shadow-card border border-gray-100 flex flex-col items-center text-center space-y-4\" style=\"opacity:0;transform:translateY(30px)\"><div class=\"w-16 h-16 bg-brand-primary text-white rounded-full flex items-center justify-center\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-target w-8 h-8\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><circle cx=\"12\" cy=\"12\" r=\"6\"></circle><circle cx=\"12\" cy=\"12\" r=\"2\"></circle></svg></div><h3 class=\"text-2xl font-bold text-brand-dark\">Our Mission</h3><p class=\"text-brand-muted leading-relaxed\">To empower athletes by providing premium-quality, high-performance sportswear that combines innovative technology with expert craftsmanship at an accessible price point.</p></div><div class=\"p-10 bg-white rounded-brand-lg shadow-card border border-gray-100 flex flex-col items-center text-center space-y-4\" style=\"opacity:0;transform:translateY(30px)\"><div class=\"w-16 h-16 bg-brand-secondary text-white rounded-full flex items-center justify-center\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-eye w-8 h-8\" aria-hidden=\"true\"><path d=\"M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0\"></path><circle cx=\"12\" cy=\"12\" r=\"3\"></circle></svg></div><h3 class=\"text-2xl font-bold text-brand-dark\">Our Vision</h3><p class=\"text-brand-muted leading-relaxed\">To become Indias most trusted manufacturer and brand for athletic wear, setting new benchmarks in quality, sustainability, and manufacturing excellence.</p></div></div></div></section><section class=\"py-24 bg-white\"><div class=\"max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"flex flex-col md:flex-row gap-16 items-center\"><div class=\"w-full md:w-1/3 aspect-[3/4] relative rounded-brand-lg overflow-hidden shadow-float\"><img alt=\"Amrit Singh Inda - Owner of FitZone\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1560250097-0b93528c311a%3Fq%3D80%26w%3D1974%26auto%3Dformat%26fit%3Dcrop&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1560250097-0b93528c311a%3Fq%3D80%26w%3D1974%26auto%3Dformat%26fit%3Dcrop&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1560250097-0b93528c311a%3Fq%3D80%26w%3D1974%26auto%3Dformat%26fit%3Dcrop&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1560250097-0b93528c311a%3Fq%3D80%26w%3D1974%26auto%3Dformat%26fit%3Dcrop&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1560250097-0b93528c311a%3Fq%3D80%26w%3D1974%26auto%3Dformat%26fit%3Dcrop&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1560250097-0b93528c311a%3Fq%3D80%26w%3D1974%26auto%3Dformat%26fit%3Dcrop&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1560250097-0b93528c311a%3Fq%3D80%26w%3D1974%26auto%3Dformat%26fit%3Dcrop&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1560250097-0b93528c311a%3Fq%3D80%26w%3D1974%26auto%3Dformat%26fit%3Dcrop&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1560250097-0b93528c311a%3Fq%3D80%26w%3D1974%26auto%3Dformat%26fit%3Dcrop&amp;w=3840&amp;q=75\"/></div><div class=\"flex-1 space-y-8\"><div class=\"space-y-4 text-center md:text-left\"><span class=\"text-brand-primary font-bold uppercase tracking-widest text-sm\">Leadership</span><h2 class=\"text-4xl font-extrabold text-brand-dark\">Meet Our Founder</h2><h3 class=\"text-2xl font-bold text-brand-secondary\">Amrit Singh Inda</h3></div><p class=\"text-lg text-brand-muted italic leading-relaxed text-center md:text-left\">&quot;At FitZone, we don&#x27;t just make clothes; we manufacture confidence. Every product that leaves our facility is a testament to our commitment to India&#x27;s growing athletic culture.&quot;</p><div class=\"flex flex-wrap gap-4 justify-center md:justify-start\"><button class=\"inline-flex items-center justify-center